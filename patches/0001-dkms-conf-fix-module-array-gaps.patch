+DEST_MODULE_LOCATION[$_idx]="/updates"
+((_idx++))
+
+BUILT_MODULE_NAME[$_idx]="ov02c10"
+BUILT_MODULE_LOCATION[$_idx]="drivers/media/i2c"
+DEST_MODULE_LOCATION[$_idx]="/updates"
+((_idx++))
